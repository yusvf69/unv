# Database - Required
# Get a free PostgreSQL database from https://neon.tech
# On Vercel: set DATABASE_URL in Project → Settings → Environment Variables (Production/Preview/Development as needed).
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth - Required for API/session signing
# On Vercel: set JWT_SECRET in Project → Settings → Environment Variables (use a long random string; do not commit real secrets).
JWT_SECRET="replace-with-a-long-random-secret"

# App
NODE_ENV="development"
PORT=8080
BASE_PATH="/"
