{
  "framework": null,
  "buildCommand": "pnpm install && pnpm --filter @workspace/universe build",
  "outputDirectory": "artifacts/universe/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ],
  "functions": {
    "api/[...path].ts": {
      "memory": 1024
    }
  }
}
