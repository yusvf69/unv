{
  "framework": null,
  "buildCommand": "pnpm run build && rm -rf public && cp -R artifacts/universe/dist/public public",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
